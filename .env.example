# ─── Local Mode ───────────────────────────────────────────────────────────────
# Path to your Obsidian vault (absolute path)
VAULT_PATH=/Users/yourname/Documents/MyVault

# Server port
PORT=3456

# Bind address — 127.0.0.1 (default, local only) or 0.0.0.0 (all interfaces)
# Use 0.0.0.0 only with AUTH_TOKEN set or behind Tailscale/VPN
BIND_ADDRESS=127.0.0.1

# Optional bearer token for authentication
# REQUIRED for cloud/public deploys unless you explicitly opt out below.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_TOKEN=

# Safe-by-default: the server refuses to bind to non-loopback addresses without
# AUTH_TOKEN unless you explicitly acknowledge the risk here.
# Set to true only for tightly controlled private networks where you intentionally
# rely on network-level auth instead of bearer-token auth.
# ALLOW_UNAUTHENTICATED_NON_LOOPBACK=false

# Maximum request body size (default: 1mb)
MAX_BODY_SIZE=1mb

# Comma-separated hostnames allowed as Origin (for DNS rebinding protection).
# localhost, 127.0.0.1, ::1, and *.ts.net are always allowed.
# Only needed if you access the server from a browser on a custom domain.
# ALLOWED_ORIGINS=myhost.example.com

# ─── Cloud Mode (Docker Compose) ─────────────────────────────────────────────
# These are only needed when using docker-compose.yml with Obsidian Headless Sync.

# Obsidian Sync auth token
# Run: docker run --rm -it --entrypoint get-token ghcr.io/belphemur/obsidian-headless-sync-docker:v0.0.8
OBSIDIAN_AUTH_TOKEN=

# Exact name of your vault in Obsidian Sync
VAULT_NAME=MyVault

# End-to-end encryption password (only if your vault has E2E encryption enabled)
VAULT_PASSWORD=

# Device name shown in Obsidian Sync history
DEVICE_NAME=obsidian-mcp-cloud

# How long obsidian-mcp waits for the vault to sync before giving up (seconds, default: 300)
# SYNC_WAIT_TIMEOUT=300

# Optional: allow get_sync_status to inspect host-level Obsidian app logs outside the vault.
# Off by default to keep the remote trust boundary inside VAULT_PATH.
# ALLOW_HOST_OBSIDIAN_LOG_READS=false
