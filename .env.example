# Path to your Obsidian vault (absolute path)
VAULT_PATH=/Users/yourname/Documents/MyVault

# Server port
PORT=3456

# Bind address — 127.0.0.1 (default, local only) or 0.0.0.0 (all interfaces)
# Use 0.0.0.0 only with AUTH_TOKEN set or behind Tailscale/VPN
BIND_ADDRESS=127.0.0.1

# Folder where daily notes live (relative to vault root)
# Examples: "Journal", "Daily Notes", "." (vault root)
DAILY_NOTE_FOLDER=Journal

# Optional bearer token for authentication
# REQUIRED when using ngrok or binding to 0.0.0.0
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_TOKEN=

# Maximum request body size (default: 1mb)
MAX_BODY_SIZE=1mb

# Optional: Obsidian vault name for deep links (obsidian://open?vault=...)
# Set this to enable clickable links in tool responses that open notes in Obsidian.
VAULT_NAME=

# ─── Cloud Mode (CouchDB + Self-hosted LiveSync) ─────────────────────────────
# Set VAULT_SOURCE=couchdb to read/write from CouchDB instead of the filesystem.
# In filesystem mode (default), only VAULT_PATH is needed.

# Backend: "filesystem" (default) or "couchdb"
VAULT_SOURCE=filesystem

# CouchDB connection (required when VAULT_SOURCE=couchdb)
COUCHDB_URL=http://localhost:5984
COUCHDB_DB=obsidian-livesync
COUCHDB_USER=admin
COUCHDB_PASSWORD=changeme

# E2E encryption passphrase (optional — only if your LiveSync vault uses encryption)
COUCHDB_ENCRYPTION_PASSPHRASE=
